# ===== Muhit =====
NODE_ENV=development
PORT=3000

# ===== Telegram bot =====
# @BotFather → /mybots → API Token (MAJBURIY)
BOT_TOKEN=

# ===== Ma'lumotlar bazasi (PostgreSQL) =====
# Variant 1: to'liq ulanish satri (Railway/Neon)
DATABASE_URL=
# Variant 2: alohida qiymatlar (DATABASE_URL bo'lmasa ishlatiladi)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=bot_loyiha
# Cloud DB (Railway/Neon) uchun SSL: true
DB_SSL=false

# ===== Chek rasmlari (ixtiyoriy) =====
# Berilsa, chek rasmlari ImgBB'ga yuklanadi (token'siz barqaror URL).
# Bo'sh bo'lsa — Telegram fayl havolasi ishlatiladi.
IMGBB_API_KEY=
